APP_NAME=dynQR
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_DEV_QUICK_LOGIN=true
APP_URL=http://dynqr.local:81

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dynqr
DB_USERNAME=dynqr
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=mailflash
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@dynqr.com"
MAIL_FROM_NAME="${APP_NAME}"

MAILFLASH_URL=http://mailflash.local:8081
MAILFLASH_API_KEY=

# STRIPE_KEY: publishable key (pk_test_... or pk_live_...)
STRIPE_KEY=
# STRIPE_SECRET: secret key (sk_test_... or sk_live_...) — NOT the publishable key
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=
STRIPE_PAID_ACTION_PRICE_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

PROXY_DOMAIN=go.dynqr.local:81
PROXY_SCHEME=http

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# QR generator engine: v1 = GD (current), v2 = SVG vector renderer + redesigned UI
QR_GENERATOR_ENGINE=v1
